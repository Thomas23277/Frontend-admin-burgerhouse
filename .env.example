# ──────────────────────────────────────────────
# 🍔 Burger House — Admin Frontend Config
# ──────────────────────────────────────────────
# Copiar a .env y editar si es necesario.

# ── API ──────────────────────────────────────
# URL base del backend (default: /api/v1 via proxy de Vite)
# En desarrollo con Vite proxy no hace falta configurar nada.
# Solo si el backend está en otro host/puerto:
# VITE_API_URL=http://localhost:8000/api/v1

# ── WebSocket ────────────────────────────────
# URL del WebSocket (opcional, default via proxy)
# VITE_WS_URL=ws://localhost:8000/ws
